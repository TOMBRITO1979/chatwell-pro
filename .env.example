# ===================================
# CHATWELL PRO - Environment Variables
# ===================================

# PostgreSQL Database Configuration
POSTGRES_PASSWORD=your_secure_postgres_password_here

# Redis Configuration
REDIS_PASSWORD=your_secure_redis_password_here

# JWT Secret (gere uma string aleatória longa e segura)
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long

# Super Admin Password (opcional - se não definido, será gerado automaticamente)
# SUPER_ADMIN_PASSWORD=

# ===================================
# Email/SMTP Configuration
# ===================================
# Configure com suas credenciais SMTP reais para:
# - Recuperação de senha
# - Notificações por email
# - Confirmações de agendamento

# Opção 1: Gmail (recomendado para desenvolvimento)
# IMPORTANTE: Use uma "Senha de App" do Gmail, não sua senha normal
# Como criar: https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu-email@gmail.com
EMAIL_PASS=sua-senha-de-app-gmail

# Opção 2: Outros provedores SMTP
# EMAIL_HOST=smtp.mailtrap.io
# EMAIL_PORT=587
# EMAIL_USER=seu-usuario-smtp
# EMAIL_PASS=sua-senha-smtp

# ===================================
# Domain Configuration
# ===================================
DOMAIN=localhost
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===================================
# Google OAuth (opcional)
# ===================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===================================
# WhatsApp API (WAHA) - Opcional
# ===================================
WAHA_BASE_URL=
WAHA_API_KEY=
